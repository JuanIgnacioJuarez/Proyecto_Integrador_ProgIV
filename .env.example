POSTGRES_USER=postgres
POSTGRES_PASSWORD=clave_postgres
POSTGRES_DB=proyecto_final
DATABASE_URL=postgresql://postgres:clave_postgres@127.0.0.1:5438/proyecto_final
PGADMIN_DEFAULT_EMAIL=admin@mail.com
PGADMIN_DEFAULT_PASSWORD=clave_pgadmin
PGADMIN_PORT=5050

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/v1/ws/pedidos
PYTHONUTF8=1

SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

DEFAULT_ADMIN_EMAIL=admin@foodstore.com
DEFAULT_ADMIN_PASSWORD=change_me
DEFAULT_STOCK_EMAIL=stock@foodstore.com
DEFAULT_STOCK_PASSWORD=change_me
DEFAULT_PEDIDOS_EMAIL=pedidos@foodstore.com
DEFAULT_PEDIDOS_PASSWORD=change_me
DEFAULT_CLIENT_EMAIL=cliente@foodstore.com
DEFAULT_CLIENT_PASSWORD=change_me

# Optional runtime flags
RUN_SEED_ON_STARTUP=false
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MercadoPago
# MP_ACCESS_TOKEN: token privado de MercadoPago, formato APP_USR-...
# MP_WEBHOOK_SECRET: secreto opcional para validar webhooks, si se configura.
# BACKEND_URL: URL publica del backend para webhooks y redirects. En local con ngrok: https://xxxxx.ngrok-free.app
# FRONTEND_URL: URL del frontend para volver desde MercadoPago. En local: http://localhost:5173
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Ngrok, solo si se usa el servicio ngrok del docker-compose.
NGROK_AUTHTOKEN=

# Cloudinary
# Opcional. Si estas variables estan completas, las imagenes de productos se suben a Cloudinary.
# Si quedan vacias, el sistema guarda imagenes localmente en backend/img.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
